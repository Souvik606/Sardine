model Animal{
    attr <name>
    attr <age,gender>
    attr <weight=10,height>

    init(name,age,gender) {
        name:name,age:2*age
        gender:gender

        Cycle i=1:4{
            show(name)
        }
    }

    method showName(){
        show(name)
    }

    method showAge(){
        show(age)
    }
}