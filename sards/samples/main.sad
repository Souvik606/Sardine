model Animal{
    attr<name>
    attr<age,gender>
    attr<weight=20,height>

    init(name,age,gender) {
        name:name,age:2*age
        gender:gender
    }

    method showName(){
        show(name)
    }

    method showAge(){
        show(age)
    }
}

cat=Animal("Tom",5,"M")
show(cat.name)
show(cat.age)
show(cat.gender)
show(cat.weight)