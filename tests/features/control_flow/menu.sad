show("--- Test: Menu Statement ---")

day = "Tuesday"

menu day {
    choice "Monday" {
        show("It's Monday.")
        escape
    }
    choice "Tuesday" {
        show("It's Tuesday.")
    }
    choice "Wednesday" {
        show("It's Wednesday.")
        escape
    }
    fallback {
        show("It's some other day.")
    }
}

val = 2
menu val {
    choice 1 {
        show("Value is 1.")
    }
    choice 2 {
        show("Value is 2.")
        escape
    }
    fallback {
        show("Value is something else.")
    }
}

other_val = 100
menu other_val {
    choice 1 {
        show("Value is 1.")
    }
    fallback {
        show("Value is something else.")
    }
}
show("--- Test: Menu Statement (Extra Valid) ---")

x = 3
menu x {
    choice 1 {
        show("V1-1.")
        escape
    }
    choice 3 {
        show("V1-3.")
        escape
    }
    fallback {
        show("V1-Default.")
    }
}

x = 1
menu x {
    choice 1 {
        show("V2-1.")
    }
    choice 2 {
        show("V2-2.")
        escape
    }
    choice 3 {
        show("V2-3.")
    }
    fallback {
        show("V2-Default.")
    }
}

x = 99
menu x {
    fallback {
        show("V3-Default.")
    }
}

day = "B"
menu day {
    choice "A" {
        show("V4-A.")
        escape
    }
    choice "B" {
        show("V4-B.")
        escape
    }
    fallback {
        show("V4-Default.")
    }
}

x = 1
y = 2
menu x {
    choice 1 {
        show("V5-Outer-1.")
        menu y {
            choice 2 {
                show("V5-Inner-2.")
                escape
            }
            fallback {
                show("V5-Inner-Default.")
            }
        }
        escape
    }
    fallback {
        show("V5-Outer-Default.")
    }
}

a = 2
menu a * 2 {
    choice 1 + 3 {
        show("V6-4.")
        escape
    }
    choice 5 {
        show("V6-5.")
        escape
    }
    fallback {
        show("V6-Default.")
    }
}

n = 0
menu n {
    choice 1 {
        show("V7-1.")
        escape
    }
    fallback {
        show("V7-Default.")
    }
}

n = 1
menu n {
    choice 1 {
        show("V8-1.")
    }
    fallback {
        show("V8-Default.")
    }
}

n = 1
menu n {
    choice 1 {
        i = 0
        whenever i < 2 {
            show("V9.")
            i = i + 1
        }
        escape
    }
    fallback {
        show("V9-Default.")
    }
}

x = 2
menu x {
    fallback {
        show("V10-Default.")
    }
    choice 2 {
        show("V10-2.")
        escape
    }
    choice 3 {
        show("V10-3.")
    }
}