show("--- Test: Arithmetic Operators ---")

show("10 + 5 =", 10 + 5)
show("10 - 5 =", 10 - 5)
show("10 * 5 =", 10 * 5)
show("10 / 5 =", 10 / 5)
show("10 // 3 =", 10 // 3)
show("10 % 3 =", 10 % 3)
show("2 ** 3 =", 2 ** 3)

show("--- Test: Augmented Assignment Operators ---")

x = 10
x += 5
show("x += 5 ->", x)

x -= 3
show("x -= 3 ->", x)

x *= 2
show("x *= 2 ->", x)

x /= 4
show("x /= 4 ->", x)

x //= 2
show("x //= 2 ->", x)

x %= 2
show("x %= 2 ->", x)

x = 3
x **= 3
show("x **= 3 ->", x)
