show("--- Test: Comparison Operators ---")

show("10 == 10 ->", 10 == 10)
show("10 == 5 ->", 10 == 5)
show("\"a\" == \"a\" ->", "a" == "a")
show("\"a\" == \"b\" ->", "a" == "b")

show("10 != 5 ->", 10 != 5)
show("10 != 10 ->", 10 != 10)
show("\"a\" != \"b\" ->", "a" != "b")
show("\"a\" != \"a\" ->", "a" != "a")

show("10 > 5 ->", 10 > 5)
show("5 > 10 ->", 5 > 10)

show("5 < 10 ->", 5 < 10)
show("10 < 5 ->", 10 < 5)

show("10 >= 10 ->", 10 >= 10)
show("10 >= 5 ->", 10 >= 5)
show("5 >= 10 ->", 5 >= 10)

show("10 <= 10 ->", 10 <= 10)
show("5 <= 10 ->", 5 <= 10)
show("10 <= 5 ->", 10 <= 5)
