a = 12
b = 5

show("--- Bitwise AND ---")
show(a & b)

show("--- Bitwise OR ---")
show(a | b)

show("--- Bitwise XOR ---")
show(a ^ b)

show("--- Bitwise NOT ---")
show(~a)

show("--- Left Shift ---")
show(a << 2)

show("--- Right Shift ---")
show(a >> 2)

show("--- Augmented Assignments ---")
c = 12
c &= 5
show(c)

d = 12
d |= 5
show(d)

e = 12
e ^= 5
show(e)

f = 12
f <<= 2
show(f)

g = 12
g >>= 2
show(g)
