show("--- Test: Complex and Nested Comprehensions ---")

show("--- Nested Comprehension (Matrix/Grid) ---")
# Creates a 3x3 multiplication table
matrix = [[i * j Cycle j = 1:3] Cycle i = 1:3]
show(matrix)

show("--- Nested List Comprehension with Variable Closure ---")
# Evaluating a list comprehension where elements themselves are generated by a list comprehension
results = [[$"x:{x},y:{y}" Cycle y = 1:2] Cycle x = 1:2]
show(results)

show("--- Complex Conditions in Comprehensions ---")
# List comprehension with a combined logical condition
evens_above_five = [x Cycle x = 1:10 when x % 2 == 0 and x > 5]
show(evens_above_five)

show("--- Dict Comprehension with Multi-variable Unpacking ---")
pairs = [["apple", 1], ["banana", 2], ["cherry", 3]]
banana_and_cherry = {k : v * 100 trace k, v <- pairs when v > 1}
show(banana_and_cherry)
